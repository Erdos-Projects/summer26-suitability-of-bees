<resourceLogoUrl>https://scan-bugs.org/portal/content/collicon/sdnhm-sdnhm-ent.png</resourceLogoUrl><onlineUrl>https://www.sdnhm.org/science/entomology/</onlineUrl><intellectualRights>http://creativecommons.org/publicdomain/zero/1.0/</intellectualRights><additionalInfo>San Diego Natural History Museum Entomology Department (SDNHM-SDNHM)</additionalInfo><associatedParty><individualName><surName>Horsley</surName><givenName>Pamela</givenName></individualName><positionName>Collection Manager</positionName><electronicMailAddress>phorsley@sdnhm.org</electronicMailAddress><userId>https://orcid.org/0000-0003-3362-2255</userId></associatedParty><associatedParty><individualName><surName>Derkarabetian</surName><givenName>Shahan</givenName></individualName><positionName>Curator</positionName><electronicMailAddress>sderkarabetian@sdnhm.org</electronicMailAddress><userId>https://orcid.org/0000-0002-9163-9277</userId></associatedParty><abstract><para>&lt;p&gt;&lt;span style="font-size: 10pt; font-family: Arial;" data-sheets-value="{" data-sheets-userformat="{"&gt;This collection is a snapshot of an external collection database where only the Bee (Apoidea:Anthophila) records are included.&lt;/span&gt;&lt;/p&gt;</para></abstract></collection><collection identifier="903ba65e-8420-4ffd-9dac-1215e88eb98b" id="8"><alternateIdentifier>https://library.big-bee.net/portal/collections/misc/collprofiles.php?collid=8</alternateIdentifier><parentCollectionIdentifier>KU</parentCollectionIdentifier><collectionIdentifier>SEMC</collectionIdentifier><collectionName>University of Kansas Natural History Museum Entomology Division</collectionName><resourceLogoUrl>https://library.big-bee.net/portal/content/collicon/kusemc.jpg</resourceLogoUrl><onlineUrl></onlineUrl><intellectualRights>https://creativecommons.org/publicdomain/zero/1.0/</intellectualRights><additionalInfo>University of Kansas Natural History Museum Entomology Division (KU-KU)</additionalInfo><associatedParty><individualName><surName>Gonzalez-Betancourt</surName><givenName>Victor</givenName></individualName><electronicMailAddress>vhgonza@ku.edu</electronicMailAddress><userId>https://orcid.org/0000-0002-4146-1634</userId></associatedParty><abstract><para>&lt;p&gt;&lt;span style="font-size: 10pt; font-family: Arial;" data-sheets-value="{&amp;quot;1&amp;quot;:2,&amp;quot;2&amp;quot;:&amp;quot;This collection is a snapshot of an external collection database where only the Bee (Apoidea:Anthophila) records are included.&amp;quot;}" data-sheets-userformat="{&amp;quot;2&amp;quot;:513,&amp;quot;3&amp;quot;:{&amp;quot;1&amp;quot;:0},&amp;quot;12&amp;quot;:0}"&gt;This collection is a snapshot of an external collection database where only the Bee (Apoidea:Anthophila) records are included.&lt;/span&gt;&lt;/p&gt;</para></abstract></collection><collection identifier="c5692872-01df-4dcf-ba74-7ae910e6b0b8" id="11"><alternateIdentifier>https://library.big-bee.net/portal/collections/misc/collprofiles.php?collid=11</alternateIdentifier><parentCollectionIdentifier>USGS PWRC</parentCollectionIdentifier><collectionIdentifier>BIML</collectionIdentifier><collectionName>USGS Native Bee Inventory and Monitoring Lab</collectionName><resourceLogoUrl>https://scan-bugs.org/portal/content/collicon/usgs-pwrc-us-ca-mx.png</resourceLogoUrl><onlineUrl>https://ipt.gbif.us/resource?r=usgs-pwrc-biml </onlineUrl><intellectualRights>http://creativecommons.org/publicdomain/zero/1.0/</intellectualRights><additionalInfo>USGS Native Bee Inventory and Monitoring Lab (USGS PWRC-USGS PWRC)</additionalInfo><associatedParty><individualName><surName>Droege</surName><givenName>Sam</givenName></individualName><electronicMailAddress>sdroege@usgs.gov</electronicMailAddress><userId>https://orcid.org/0000-0003-4393-0403</userId></associatedParty><abstract><para>&lt;p&gt;This collection is a snapshot of an external collection database where only the Bee (Apoidea:Anthophila) records are included.&lt;/p&gt;</para></abstract></collection><collection identifier="8011f62e-ea94-4fcd-b545-9ad1060d1a3f" id="12"><alternateIdentifier>https://library.big-bee.net/portal/collections/misc/collprofiles.php?collid=12</alternateIdentifier><parentCollectionIdentifier>USDA-ARS</parentCollectionIdentifier><collectionIdentifier>BBSL</collectionIdentifier><collectionName>Bee Biology and Systematics Laboratory, USDA-ARS Pollinating Insect-Biology, Management, Systematics Research</collectionName><resourceLogoUrl>http://scan-bugs.org/portal/content/collicon/usda-ars.png</resourceLogoUrl><onlineUrl></onlineUrl><intellectualRights>http://creativecommons.org/licenses/by/4.0/</intellectualRights><additionalInfo>Bee Biology and Systematics Laboratory, USDA-ARS Pollinating Insect-Biology, Management, Systematics Research (USDA-ARS-USDA-ARS)</additionalInfo><associatedParty><individualName><surName>Griswold</surName><givenName>Terry</givenName></individualName><electronicMailAddress>Terry.Griswold@ars.usda.gov</electronicMailAddress><userId>https://orcid.org/0000-0003-3952-9393</userId></associatedParty><abstract><para>&lt;p&gt;This is a one-time snapshot collection of data originally hosted by GBIF: &lt;a href="http://www.gbif.org/publisher/1e26a630-7203-11dc-a0d8-b8a03c50a862" target="_blank" rel="noopener"&gt;http://www.gbif.org/publisher/1e26a630-7203-11dc-a0d8-b8a03c50a862&lt;/a&gt;&lt;/p&gt;&#13;
&lt;p&gt;&lt;strong&gt;Citation:&lt;/strong&gt; USDA-ARS Bee Biology and Systematics Laboratory. Bee Biology and Systematics Laboratory. Occurrence Dataset &lt;a href="https://doi.org/10.15468/anyror" target="_blank" rel="noopener"&gt;https://doi.org/10.15468/anyror&lt;/a&gt; accessed via GBIF.org on 2018-02-28.&lt;/p&gt;&#13;
&lt;p&gt;&lt;strong&gt;Temporal range:&lt;/strong&gt; August 7, 1819 - August 25, 2012&lt;/p&gt;&#13;
&lt;p&gt;&lt;strong&gt;Publication date:&lt;/strong&gt; November 26, 2019&lt;/p&gt;&#13;
&lt;p&gt;The Pollinating Insects -- Biology, Management and Systematics Research Unit (PIRU) was founded in the late 1940s as part of the alfalfa seed production unit. We focus primarily on pollination research with bees.The mission of the Pollinating Insect - Biology, Management and Systematics Research Unit is the development of non-Apis bees, for example the alfalfa leafcutting bee and blue orchard bee, as crop pollinators. Research emphasis areas include the development and improvement of management systems for bee populations, biological studies of bees, plant-pollination systems, and bee biosystematics. Cross-pollinated crops not effectively pollinated by honey bees have been targeted for improved pollination management, and the candidacy of selected pollinator species continues to be evaluated. Current research on established species, like the alfalfa leafcutting bee and blue orchard bee, is directed toward developing control programs for pests and diseases, improving management that will result in better bee health and demonstrating pollination efficacy and increased producer profitability on "new" crops.&lt;/p&gt;</para></abstract></collection><collection identifier="718754c5-cede-48e8-b5f4-1961708533dd" id="15"><alternateIdentifier>https://library.big-bee.net/portal/collections/misc/collprofiles.php?collid=15</alternateIdentifier><parentCollectionIdentifier>iNat</parentCollectionIdentifier><collectionIdentifier></collectionIdentifier><collectionName>iNaturalist Research-Grade Observations</collectionName><resourceLogoUrl>http://scan-bugs.org/portal/images/collicons/inat-bird-logo.png</resourceLogoUrl><onlineUrl></onlineUrl><intellectualRights>http://creativecommons.org/publicdomain/zero/1.0/</intellectualRights><additionalInfo>iNaturalist Research-Grade Observations (iNat-iNat)</additionalInfo><abstract><para>&lt;p&gt;This is a snapshot collection of Research-Grade observations from the iNaturalist.org platform as &lt;a href="https://www.gbif.org/dataset/50c9509d-22c7-4a22-a47d-8c48425ef4a7"&gt;published through GBIF.&lt;/a&gt;&lt;/p&gt;&#13;
&lt;p&gt;&amp;nbsp;&lt;/p&gt;&#13;
&lt;p&gt;The dataset was searched for the seven families within Anthophila and is available here:&lt;/p&gt;&#13;
&lt;p&gt;GBIF.org (03 November 2021) GBIF Occurrence Download&amp;nbsp; https://doi.org/10.15468/dl.aw9qu4&lt;/p&gt;</para></abstract></collection><collection identifier="f7b5b898-057a-4052-8086-20b9a8be2309" id="16"><alternateIdentifier>https://library.big-bee.net/portal/collections/misc/collprofiles.php?collid=16</alternateIdentifier><parentCollectionIdentifier>NMNH</parentCollectionIdentifier><collectionIdentifier>ENT</collectionIdentifier><collectionName>Smithsonian Institution, National Museum of Natural History, Entomology Collection</collectionName><resourceLogoUrl>https://lichenportal.org/portal/content/collicon/us.jpg</resourceLogoUrl><onlineUrl></onlineUrl><intellectualRights>https://creativecommons.org/publicdomain/zero/1.0/</intellectualRights><additionalInfo>Smithsonian Institution, National Museum of Natural History, Entomology Collection (NMNH-NMNH)</additionalInfo><abstract><para>&lt;p&gt;This collection contains the Anthophila records published by the NMNH Entomology Collection.&lt;/p&gt;</para></abstract></collection><collection identifier="90003559-9508-4977-a53d-b69618269249" id="40"><alternateIdentifier>https://library.big-bee.net/portal/collections/misc/collprofiles.php?collid=40</alternateIdentifier><parentCollectionIdentifier>SDNHM</parentCollectionIdentifier><collectionIdentifier>SDC</collectionIdentifier><collectionName>San Diego County Bee Checklist</collectionName><resourceLogoUrl>https://library.big-bee.net/portal/content/collicon/sdnhmsdc.jpeg</resourceLogoUrl><onlineUrl>https://library.ucsd.edu/dc/collection/bb3180261d</onlineUrl><intellectualRights>http://creativecommons.org/licenses/by/4.0/</intellectualRights><additionalInfo>Regents of the University of California</additionalInfo><associatedParty><individualName><surName>Mullins</surName><givenName>Jessica</givenName></individualName><positionName>PhD student</positionName><electronicMailAddress>jmullins@ucsd.edu</electronicMailAddress><userId>https://orcid.org/0000-0001-7907-2370</userId></associatedParty><associatedParty><individualName><surName>Hung</surName><givenName>James</givenName></individualName><positionName>Assistant Professor</positionName><electronicMailAddress>kenglou.hung@gmail.com</electronicMailAddress><userId>https://orcid.org/0000-0002-1557-3958</userId></associatedParty><abstract><para>&lt;p&gt;This is a collection of bees collected in San Diego County, California. All bees are pinned specimens currently stored at the University of California San Diego in David Holway's lab and will be vouchered at the San Diego Natural History Museum.&lt;/p&gt;</para></abstract></collection><collection identifier="b2c7bfb8-6d48-4cbb-a249-d717c0bd4565" id="50"><alternateIdentifier>https://library.big-bee.net/portal/collections/misc/collprofiles.php?collid=50</alternateIdentifier><parentCollectionIdentifier>BOLD</parentCollectionIdentifier><collectionIdentifier></collectionIdentifier><collectionName>Barcode of Life</collectionName><onlineUrl>https://www.boldsystems.org/index.php/</onlineUrl><intellectualRights>http://creativecommons.org/publicdomain/zero/1.0/</intellectualRights><additionalInfo>Barcode of Life (BOLD-BOLD)</additionalInfo><abstract><para>&lt;p&gt;Dataset compiled from the Barcode of Life Data Portal (BOLD): Ratnasingham, Sujeevan, and Paul D N Hebert. &amp;ldquo;bold: The Barcode of Life Data System (http://www.barcodinglife.org).&amp;rdquo; Molecular ecology notes vol. 7,3 (2007): 355-364. doi:&lt;a href="https://doi.org/10.1111/j.1471-8286.2007.01678.x"&gt;10.1111/j.1471-8286.2007.01678.x&lt;/a&gt;&lt;/p&gt;</para></abstract></collection><collection identifier="3d8c4503-2d90-4610-98bf-b902663ae990" id="52"><alternateIdentifier>https://library.big-bee.net/portal/collections/misc/collprofiles.php?collid=52</alternateIdentifier><parentCollectionIdentifier>WRME</parentCollectionIdentifier><collectionIdentifier></collectionIdentifier><collectionName>J. B. Wallis / R. E. Roughley Museum of Entomology</collectionName><onlineUrl>https://umanitoba.ca/agricultural-food-sciences/wallis-roughley-museum-entomology</onlineUrl><intellectualRights>http://creativecommons.org/licenses/by/4.0/</intellectualRights><additionalInfo>J. B. Wallis / R. E. Roughley Museum of Entomology (WRME-WRME)</additionalInfo><associatedParty><individualName><surName>Gibbs</surName><givenName>Jason</givenName></individualName><positionName>Curator</positionName><electronicMailAddress>jason.gibbs@umanitoba.ca</electronicMailAddress><userId>https://orcid.org/0000-0002-4945-5423</userId></associatedParty><associatedParty><individualName><surName>Lee</surName><givenName>Wonhyo</givenName></individualName><positionName>Technician</positionName><electronicMailAddress>Wonhyo.Lee@umanitoba.ca</electronicMailAddress></associatedParty><abstract><para>&lt;p&gt;Invertebrate collection, primarily insects (pinned, slides, and fluid preserved) with good representation for Manitoba, Canada and strengths in bees and aquatic beetles&lt;/p&gt;</para></abstract></collection><collection identifier="83b23613-3d47-42f7-b4eb-70a05eae953c" id="75"><alternateIdentifier>https://library.big-bee.net/portal/collections/misc/collprofiles.php?collid=75</alternateIdentifier><parentCollectionIdentifier>UCSD</parentCollectionIdentifier><collectionIdentifier></collectionIdentifier><collectionName>UCSD Holway Lab - Longterm Habitat Fragmentation Study</collectionName><onlineUrl></onlineUrl><intellectualRights>https://creativecommons.org/licenses/by-nc/4.0/</intellectualRights><additionalInfo>UCSD Holway Lab - Longterm Habitat Fragmentation Study (UCSD-UCSD)</additionalInfo><associatedParty><individualName><surName>Mullins</surName><givenName>Jessica</givenName></individualName><positionName>PhD Student</positionName><electronicMailAddress>jmullins@ucsd.edu</electronicMailAddress><userId>https://orcid.org/0000-0001-7907-2370</userId></associatedParty><associatedParty><individualName><surName>Hung</surName><givenName>James</givenName></individualName><positionName>Professor</positionName><electronicMailAddress>KengLou.Hung@gmail.com </electronicMailAddress><userId>https://orcid.org/0000-0002-1557-3958</userId></associatedParty><abstract><para>&lt;p&gt;This is a multi-year dataset collected by Keng-Lou James Hung and Jessica Mullins in San Diego County as a part of research in Dr. David Holway's lab between 2011 and 2024. These projects assess various aspects of how land-use type and climate change impact native bee assemblages&lt;/p&gt;</para></abstract></collection></symbiota></metadata></additionalMetadata></eml:eml>
